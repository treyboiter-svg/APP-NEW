# OverlineEdge v8.3 — API Keys
# Copy this file to .env and fill in your real keys.
# .env is gitignored and NEVER committed.
#
# Weather (primary — best accuracy, station pressure, 3h forecast)
OPENWEATHER_API_KEY=your_openweathermap_key_here
#
# Elevation lookup (when a venue is missing from the workbook)
GOOGLE_ELEV_KEY=your_google_elevation_api_key_here
#
# Geocoding (lat/lon lookup for venues not in workbook)
OPENCAGEAPIKEY=your_opencage_api_key_here
GOOGLE_MAPS_KEY=your_google_maps_api_key_here
#
# End of .env.example
